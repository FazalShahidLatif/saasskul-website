# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SaaSSkul

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create these in Stripe dashboard)
STRIPE_STARTER_PRICE_ID=price_starter_id
STRIPE_GROWTH_PRICE_ID=price_growth_id
STRIPE_AGENCY_PRICE_ID=price_agency_id

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@saaskul.com
CONTACT_EMAIL=hello@saaskul.com

# AI Chatbot
ANTHROPIC_API_KEY=

# Paddle Payments (Sandbox / Test)
# Get from: vendors.paddle.com (sandbox) → Developer Tools
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxx
PADDLE_API_KEY=your_paddle_sandbox_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret

# Paddle Price IDs — create products in Paddle sandbox dashboard
NEXT_PUBLIC_PADDLE_STARTER_PRICE_ID=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_GROWTH_PRICE_ID=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_AGENCY_PRICE_ID=pri_xxxxxxxxxxxxxxxx
