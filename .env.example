# ============================================================
# SaaSSkul — Environment Variables
# Copy this file to .env.local for local development
# Set all variables in Hostinger → Node.js → Environment Variables
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://saasskul.com

# ── Supabase (required — get from supabase.com/dashboard) ───
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://czzyviuyefhfcnhkbnkg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── AI Chatbot (required — get from console.anthropic.com) ──
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Paddle Payments (get from vendors.paddle.com) ────────────
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_paddle_client_token
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret

# Paddle Price IDs — create in Paddle dashboard → Catalog → Products
NEXT_PUBLIC_PADDLE_STARTER_PRICE_ID=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_GROWTH_PRICE_ID=pri_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_AGENCY_PRICE_ID=pri_xxxxxxxxxxxxxxxx

# ── Email — Resend (optional — get from resend.com) ──────────
# Enables contact form to actually send emails
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=hello@saasskul.com
CONTACT_EMAIL=hello@saasskul.com

# ── Google Analytics (optional) ──────────────────────────────
# Already hardcoded as G-RPBLRYT5L3 — only needed if you change it
NEXT_PUBLIC_GA_ID=G-RPBLRYT5L3

# ── Google Search Console verification (optional) ────────────
# Authentication → HTML tag → content="..." value
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token
